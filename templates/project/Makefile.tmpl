{{- /* Code generated by sgctl. DO NOT EDIT. */ -}}
# ─── {{ .Module }} ─────────────────────────────────────────────
#
# Build:
#   proto              — .proto → Go stubs (requires protoc)
#   build              — build all binaries
#   build-server       — {{ .Project.Name }}-backend
#   build-apiserver    — {{ .Project.Name }}-k8s-apiserver
#   test / lint        — go vet + go test / golangci-lint
#   clean              — remove binaries + proto stubs
#
# Docker:
#   docker-build       — all images
#   docker-build-server / docker-build-apiserver / docker-build-migration
#
# Kind (local development cluster):
#   kind-up            — create cluster + cert-manager + docker-build + deploy
#   kind-down          — undeploy + delete cluster
#   kind-create / kind-delete
#   docker-load        — load images into Kind
#
# Deploy:
#   deploy             — apply K8s manifests (postgres → backend+migration → apiserver)
#   undeploy           — delete K8s manifests
#   redeploy-backend / redeploy-apiserver / remigrate
#
# Observability:
#   status / logs-backend / logs-apiserver
#   proxy              — kubectl proxy for AGL API
#   port-forward-backend / port-forward-postgres
#

MODULE         := {{ .Module }}
BIN            := ./bin

IMAGE_BACKEND    := {{ .Project.Name }}-backend:latest
IMAGE_APISERVER  := {{ .Project.Name }}-k8s-apiserver:latest
IMAGE_MIGRATION  := {{ .Project.Name }}-migration:latest

KIND_CLUSTER     := {{ .Project.Name }}-dev
NAMESPACE        := {{ .Project.Name }}-system
CERT_MANAGER_VER := v1.17.2
PROXY_PORT       := 8001

PROTO_SRC        := api/proto
PROTO_INCLUDE    := -I $(PROTO_SRC)

.PHONY: proto build build-server build-apiserver test lint clean \
        docker-build docker-build-server docker-build-apiserver docker-build-migration \
        docker-load \
        kind-create kind-delete kind-up kind-down cert-manager \
        deploy undeploy \
        redeploy-backend redeploy-apiserver remigrate \
        status logs-backend logs-apiserver \
        proxy port-forward-backend port-forward-postgres

# ═══════════════════════════════════════════════════════════════════
#  Proto / Build / Test
# ═══════════════════════════════════════════════════════════════════

proto:
	protoc --go_out=. --go_opt=module=$(MODULE) \
	       --go-grpc_out=. --go-grpc_opt=module=$(MODULE) \
	       --grpc-gateway_out=. --grpc-gateway_opt=module=$(MODULE),logtostderr=true \
	       $(PROTO_INCLUDE) \
	       $(PROTO_SRC)/{{ .Project.Name }}/v1/*.proto

build: build-server build-apiserver

build-server:
	@mkdir -p $(BIN)
	CGO_ENABLED=0 go build -ldflags="-s -w" -o $(BIN)/{{ .Project.Name }}-backend ./cmd/{{ .Project.Name }}-backend

build-apiserver:
	@mkdir -p $(BIN)
	CGO_ENABLED=0 go build -ldflags="-s -w" -o $(BIN)/{{ .Project.Name }}-k8s-apiserver ./cmd/{{ .Project.Name }}-k8s-apiserver

test:
	go vet ./...
	go test ./...

lint:
	golangci-lint run ./...

clean:
	rm -rf $(BIN)
	rm -rf pkg/api/{{ .Project.Name }}/v1/*.go

# ═══════════════════════════════════════════════════════════════════
#  Docker
# ═══════════════════════════════════════════════════════════════════

docker-build: docker-build-server docker-build-apiserver docker-build-migration

docker-build-server:
	docker build -f build/docker/server.Dockerfile -t $(IMAGE_BACKEND) .

docker-build-apiserver:
	docker build -f build/docker/apiserver.Dockerfile -t $(IMAGE_APISERVER) .

docker-build-migration:
	docker build -f build/docker/migration.Dockerfile -t $(IMAGE_MIGRATION) .

# ═══════════════════════════════════════════════════════════════════
#  Kind
# ═══════════════════════════════════════════════════════════════════

kind-up: kind-create cert-manager docker-build docker-load deploy
	@echo "{{ .Project.Name }} stack is up. Run 'make status' to check."

kind-down: undeploy kind-delete
	@echo "{{ .Project.Name }} stack is down."

kind-create:
	@if ! kind get clusters 2>/dev/null | grep -q '^$(KIND_CLUSTER)$$'; then \
		kind create cluster --name $(KIND_CLUSTER); \
	else \
		echo "Kind cluster '$(KIND_CLUSTER)' already exists"; \
	fi

kind-delete:
	kind delete cluster --name $(KIND_CLUSTER)

cert-manager:
	kubectl apply -f https://github.com/cert-manager/cert-manager/releases/download/$(CERT_MANAGER_VER)/cert-manager.yaml
	@echo "Waiting for cert-manager..."
	kubectl wait --for=condition=Available deployment/cert-manager -n cert-manager --timeout=120s
	kubectl wait --for=condition=Available deployment/cert-manager-webhook -n cert-manager --timeout=120s
	kubectl wait --for=condition=Available deployment/cert-manager-cainjector -n cert-manager --timeout=120s

# ═══════════════════════════════════════════════════════════════════
#  Deploy
# ═══════════════════════════════════════════════════════════════════

docker-load:
	kind load docker-image $(IMAGE_BACKEND)   --name $(KIND_CLUSTER)
	kind load docker-image $(IMAGE_MIGRATION) --name $(KIND_CLUSTER)
	kind load docker-image $(IMAGE_APISERVER) --name $(KIND_CLUSTER)

deploy:
	kubectl create namespace $(NAMESPACE) --dry-run=client -o yaml | kubectl apply -f -
	@echo "Deploying PostgreSQL..."
	kubectl apply -f deploy/postgres.yaml -n $(NAMESPACE)
	kubectl wait --for=condition=Ready pod -l app={{ .Project.Name }}-postgres -n $(NAMESPACE) --timeout=120s
	@echo "Deploying backend (goose migration runs as init-container)..."
	kubectl apply -f deploy/backend.yaml -n $(NAMESPACE)
	kubectl rollout status deployment/{{ .Project.Name }}-backend -n $(NAMESPACE) --timeout=180s
	@echo "Deploying apiserver..."
	kubectl apply -f deploy/apiserver.yaml
	kubectl apply -f deploy/apiservice_gen.yaml
	kubectl rollout status deployment/{{ .Project.Name }}-k8s-apiserver -n $(NAMESPACE) --timeout=120s
	@echo "All components deployed."

undeploy:
	-kubectl delete -f deploy/apiservice_gen.yaml --ignore-not-found
	-kubectl delete -f deploy/apiserver.yaml -n $(NAMESPACE) --ignore-not-found
	-kubectl delete -f deploy/backend.yaml -n $(NAMESPACE) --ignore-not-found
	-kubectl delete -f deploy/postgres.yaml -n $(NAMESPACE) --ignore-not-found

redeploy-backend: docker-build-server docker-build-migration
	kind load docker-image $(IMAGE_BACKEND) --name $(KIND_CLUSTER)
	kind load docker-image $(IMAGE_MIGRATION) --name $(KIND_CLUSTER)
	kubectl rollout restart deployment/{{ .Project.Name }}-backend -n $(NAMESPACE)
	kubectl rollout status deployment/{{ .Project.Name }}-backend -n $(NAMESPACE) --timeout=180s

redeploy-apiserver: docker-build-apiserver
	kind load docker-image $(IMAGE_APISERVER) --name $(KIND_CLUSTER)
	kubectl rollout restart deployment/{{ .Project.Name }}-k8s-apiserver -n $(NAMESPACE)
	kubectl rollout status deployment/{{ .Project.Name }}-k8s-apiserver -n $(NAMESPACE) --timeout=120s

remigrate: docker-build-migration
	kind load docker-image $(IMAGE_MIGRATION) --name $(KIND_CLUSTER)
	kubectl rollout restart deployment/{{ .Project.Name }}-backend -n $(NAMESPACE)
	kubectl rollout status deployment/{{ .Project.Name }}-backend -n $(NAMESPACE) --timeout=180s

# ═══════════════════════════════════════════════════════════════════
#  Observability
# ═══════════════════════════════════════════════════════════════════

status:
	kubectl -n $(NAMESPACE) get all

logs-backend:
	kubectl logs -f deployment/{{ .Project.Name }}-backend -n $(NAMESPACE)

logs-apiserver:
	kubectl logs -f deployment/{{ .Project.Name }}-k8s-apiserver -n $(NAMESPACE)

proxy:
	@echo "K8s API proxy: http://localhost:$(PROXY_PORT)"
	@echo "  Tenants: http://localhost:$(PROXY_PORT)/apis/{{ .Project.APIGroup }}/{{ .Project.APIVersion }}/tenants"
	kubectl proxy --port=$(PROXY_PORT)

port-forward-backend:
	@echo "gRPC/HTTP backend: localhost:9006"
	kubectl port-forward svc/{{ .Project.Name }}-backend 9006:9006 -n $(NAMESPACE)

port-forward-postgres:
	@echo "PostgreSQL: localhost:15432"
	kubectl port-forward svc/{{ .Project.Name }}-postgres 15432:5432 -n $(NAMESPACE)
