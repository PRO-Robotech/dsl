{{- else }}
    'env=>prod, tier=>backend',
    'created-by=>sgctl'
{{- end }}
);
{{- end }}
{{- end }}
{{- end }}
{{- end }}

-- ═══ INSERT: binding resources ═══════════════════════════════════════════
{{- range $ri, $res := .Resources }}
