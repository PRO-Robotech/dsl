SET LOCAL search_path TO {{ .DBSchema }}, public;

BEGIN;

-- ═══ TRUNCATE (reverse dependency order) ═════════════════════════════════
{{- range $ri, $res := .Resources }}
{{- if not $res.IsComposite }}
{{- if $res.IsBinding }}
TRUNCATE {{ $.DBSchema }}.tbl_{{ $res.Table }} CASCADE;
{{- end }}
{{- end }}
{{- end }}
{{- range $ri, $res := .Resources }}
{{- if not $res.IsComposite }}
{{- if and $res.IsNamespaced (not $res.IsBinding) }}
TRUNCATE {{ $.DBSchema }}.tbl_{{ $res.Table }} CASCADE;
{{- end }}
{{- end }}
{{- end }}
{{- range $ri, $res := .Resources }}
{{- if not $res.IsComposite }}
{{- if $res.IsCluster }}
TRUNCATE {{ $.DBSchema }}.tbl_{{ $res.Table }} CASCADE;
{{- end }}
{{- end }}
{{- end }}

-- ═══ INSERT: cluster-scoped (primary) resources ══════════════════════════
{{- range $ri, $res := .Resources }}
{{- if not $res.IsComposite }}
{{- if $res.IsCluster }}
{{- $kebabName := kebab $res.Name }}

-- {{ $res.Name }} (6 records)
{{- range $i := seq 6 }}
{{- $idx := sub $i 1 }}
INSERT INTO {{ $.DBSchema }}.tbl_{{ $res.Table }} (
    uid, name,
{{- range $res.Spec.Fields }}
    {{ .ColumnName }},
{{- end }}
    display_name, description, labels, annotations
) VALUES (
    '00000000-0000-0000-0000-{{ printf "%04d" $idx }}00000000',
    '{{ $kebabName }}-{{ $idx }}',
{{- range $res.Spec.Fields }}
{{- if .TestSQLValue }}
    {{ .TestSQLValue }},
{{- else if eq .SQLType "bool" }}
    {{ if eq $idx 0 }}true{{ else }}false{{ end }},
{{- else if eq .SQLType "integer" }}
    {{ $idx }},
{{- else if eq .SQLType "bigint" }}
    {{ $idx }},
{{- else if eq .SQLType "jsonb" }}
    '{}',
{{- else if eq .SQLType "cidr" }}
    '10.{{ $idx }}.0.0/16',
{{- else if contains .SQLType "[]" }}
    '{}',
{{- else if .EnumValues }}
    '{{ index .EnumValues (mod $idx (len .EnumValues)) }}',
{{- else }}
    '{{ $kebabName }}-{{ $idx }}-{{ snakeCase .Name }}',
{{- end }}
{{- end }}
    '{{ $res.Name }} {{ $idx }}',
    'Test {{ lower $res.Name }} number {{ $idx }}',
{{- if eq $idx 0 }}
    'env=>test, tier=>frontend',
    'created-by=>sgctl'
{{- else if eq $idx 1 }}
    'env=>test, tier=>backend',
    'created-by=>sgctl'
{{- else if eq $idx 2 }}
    'env=>staging, tier=>frontend',
    'created-by=>manual'
{{- else }}
    'env=>prod, tier=>backend',
    'created-by=>sgctl'
{{- end }}
);
{{- end }}
{{- end }}
{{- end }}
{{- end }}

-- ═══ INSERT: namespaced non-binding (secondary) resources ════════════════
{{- range $ri, $res := .Resources }}
