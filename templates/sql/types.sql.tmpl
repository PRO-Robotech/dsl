-- DO NOT EDIT: generated by sgctl from schema.yaml
-- Custom SQL types, enums, composites

SET LOCAL search_path TO {{ .Schema }}, public;

{{ range .Enums -}}
DO $$ BEGIN
  CREATE TYPE {{ $.Schema }}.{{ snakeCase .Name }} AS ENUM ({{ joinQuoted .Values }});
EXCEPTION WHEN duplicate_object THEN NULL;
END $$;

{{ end -}}

{{- range .Composites -}}
{{- $numFields := len .Fields -}}
DO $$ BEGIN
  CREATE TYPE {{ $.Schema }}.{{ snakeCase .Name }} AS (
    {{- range $i, $f := .Fields }}
    {{ snakeCase $f.Name }} {{ snakeCase $f.Type }}{{ if lt (add $i 1) $numFields }},{{ end }}
    {{- end }}
  );
EXCEPTION WHEN duplicate_object THEN NULL;
END $$;

{{ end -}}
