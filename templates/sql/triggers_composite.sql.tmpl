-- DO NOT EDIT: generated by sgctl
-- Triggers for composite resource: {{ .Res.Name }}

{{ range .Res.Subtypes }}
-- Triggers for {{ $.Schema }}.tbl_{{ .Table }}

CREATE OR REPLACE TRIGGER trg_{{ .Table }}_immutable_fields
    BEFORE UPDATE ON {{ $.Schema }}.tbl_{{ .Table }}
    FOR EACH ROW
    EXECUTE FUNCTION {{ $.Schema }}.forbid_fields_update_trg({{ joinQuoted $.Res.Immutable }});

CREATE OR REPLACE TRIGGER trg_{{ .Table }}_resource_version
    BEFORE INSERT OR UPDATE ON {{ $.Schema }}.tbl_{{ .Table }}
    FOR EACH ROW
    EXECUTE FUNCTION {{ $.Schema }}.inc_resource_version_cnt();

CREATE OR REPLACE TRIGGER trg_{{ .Table }}_outbox_au
    AFTER INSERT OR UPDATE ON {{ $.Schema }}.tbl_{{ .Table }}
    FOR EACH ROW
    EXECUTE FUNCTION {{ $.Schema }}.capture_outbox_resource_events_trg(
        '{{ $.Res.Name }}{{ .Name }}', 'vu_{{ .Table }}', 'uid'
    );

CREATE OR REPLACE TRIGGER trg_{{ .Table }}_outbox_bd
    BEFORE DELETE ON {{ $.Schema }}.tbl_{{ .Table }}
    FOR EACH ROW
    EXECUTE FUNCTION {{ $.Schema }}.capture_outbox_resource_events_trg(
        '{{ $.Res.Name }}{{ .Name }}', 'vu_{{ .Table }}', 'uid'
    );

CREATE OR REPLACE TRIGGER trg_{{ .Table }}_notify
    AFTER INSERT ON {{ $.Schema }}.tbl_outbox_resource_events
    FOR EACH ROW
    WHEN (NEW.resource_type = '{{ $.Res.Name }}{{ .Name }}')
    EXECUTE FUNCTION {{ $.Schema }}.notify_outbox_resource_events_trg('resource_{{ $.Res.Name }}{{ .Name }}');

{{ end }}
