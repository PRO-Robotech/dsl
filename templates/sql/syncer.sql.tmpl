-- DO NOT EDIT: generated by sgctl
-- Syncer: {{ .Schema }}.sync_{{ .Res.Table }}s

-- Row type for sync input
DO $$ BEGIN
  CREATE TYPE {{ .Schema }}.row_of__{{ .Res.Table }} AS (
    uid            uuid,
    name           {{ .Schema }}.rname,
{{- if .Res.IsNamespaced }}
    namespace      {{ .Schema }}.rname,
{{- end }}
{{- range .Res.Refs }}
    {{ .SQLColumn }}  {{ $.Schema }}.rname,
{{- end }}
{{- range .Res.Spec.Fields }}
{{- if not .OutputOnly }}
    {{ .ColumnName }}  {{ .SQLType }},
{{- end }}
{{- end }}
    display_name   text,
    description    text,
    comment        text,
    labels         hstore,
    annotations    hstore,
    resource_version bigint
  );
EXCEPTION WHEN duplicate_object THEN NULL;
END $$;

CREATE OR REPLACE FUNCTION {{ .Schema }}.sync_{{ .Res.Table }}s(
    _op   text,
    _data {{ .Schema }}.row_of__{{ .Res.Table }}[]
)
RETURNS TABLE(
    uid  uuid,
    name {{ .Schema }}.rname
)
LANGUAGE plpgsql
AS $$
DECLARE
    _row {{ .Schema }}.row_of__{{ .Res.Table }};
BEGIN
    FOREACH _row IN ARRAY _data LOOP
        IF _op = 'ups' THEN
            INSERT INTO {{ .Schema }}.tbl_{{ .Res.Table }} (
                uid, name{{ if .Res.IsNamespaced }}, namespace{{ end -}}
{{- range .Res.Refs }}, {{ .SQLColumn }}{{ end -}}
{{- range .Res.Spec.Fields }}{{ if not .OutputOnly }}, {{ .ColumnName }}{{ end }}{{ end -}}
, display_name, description, comment, labels, annotations, resource_version
            ) VALUES (
                COALESCE(_row.uid, gen_random_uuid()),
                _row.name{{ if .Res.IsNamespaced }}, _row.namespace{{ end -}}
{{- range .Res.Refs }}, _row.{{ .SQLColumn }}{{ end -}}
{{- range .Res.Spec.Fields }}{{ if not .OutputOnly }}, _row.{{ .ColumnName }}{{ end }}{{ end -}}
, COALESCE(_row.display_name, ''),
                COALESCE(_row.description, ''),
                COALESCE(_row.comment, ''),
                COALESCE(_row.labels, ''::hstore),
                COALESCE(_row.annotations, ''::hstore),
                _row.resource_version
            )
            ON CONFLICT ON CONSTRAINT uq_{{ .Res.Table }}_name DO UPDATE SET
{{- range .Res.Spec.Fields }}
{{- if not .OutputOnly }}
                {{ .ColumnName }} = EXCLUDED.{{ .ColumnName }},
{{- end }}
{{- end }}
                display_name = EXCLUDED.display_name,
                description  = EXCLUDED.description,
                comment      = EXCLUDED.comment,
                labels       = EXCLUDED.labels,
                annotations  = EXCLUDED.annotations,
                resource_version = EXCLUDED.resource_version
            RETURNING tbl_{{ .Res.Table }}.uid, tbl_{{ .Res.Table }}.name
            INTO uid, name;
        ELSIF _op = 'del' THEN
            DELETE FROM {{ .Schema }}.tbl_{{ .Res.Table }}
            WHERE {{ .Schema }}.tbl_{{ .Res.Table }}.name = _row.name
{{- if .Res.IsNamespaced }}
              AND {{ .Schema }}.tbl_{{ .Res.Table }}.namespace = _row.namespace
{{- end }}
            RETURNING tbl_{{ .Res.Table }}.uid, tbl_{{ .Res.Table }}.name
            INTO uid, name;
        END IF;
        IF uid IS NOT NULL THEN
            RETURN NEXT;
        END IF;
    END LOOP;
END;
$$;

