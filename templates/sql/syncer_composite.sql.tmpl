-- DO NOT EDIT: generated by sgctl
-- Syncers for composite resource: {{ .Res.Name }}

{{ range .Res.Subtypes }}
DO $$ BEGIN
  CREATE TYPE {{ $.Schema }}.row_of__{{ .Table }} AS (
    uid            uuid,
    name           {{ $.Schema }}.rname,
    namespace      {{ $.Schema }}.rname,
    display_name   text,
    description    text,
    comment        text,
    labels         hstore,
    annotations    hstore,
    resource_version bigint
  );
EXCEPTION WHEN duplicate_object THEN NULL;
END $$;

CREATE OR REPLACE FUNCTION {{ $.Schema }}.sync_{{ .Table }}s(
    _op   text,
    _data {{ $.Schema }}.row_of__{{ .Table }}[]
)
RETURNS TABLE(
    uid  uuid,
    name {{ $.Schema }}.rname
)
LANGUAGE plpgsql
AS $$
DECLARE
    _row {{ $.Schema }}.row_of__{{ .Table }};
BEGIN
    FOREACH _row IN ARRAY _data LOOP
        IF _op = 'ups' THEN
            INSERT INTO {{ $.Schema }}.tbl_{{ .Table }} (
                uid, name, namespace,
                display_name, description, comment,
                labels, annotations, resource_version
            ) VALUES (
                COALESCE(_row.uid, gen_random_uuid()),
                _row.name, _row.namespace,
                COALESCE(_row.display_name, ''),
                COALESCE(_row.description, ''),
                COALESCE(_row.comment, ''),
                COALESCE(_row.labels, ''::hstore),
                COALESCE(_row.annotations, ''::hstore),
                _row.resource_version
            )
            ON CONFLICT ON CONSTRAINT uq_{{ .Table }}_name DO UPDATE SET
                display_name = EXCLUDED.display_name,
                description  = EXCLUDED.description,
                comment      = EXCLUDED.comment,
                labels       = EXCLUDED.labels,
                annotations  = EXCLUDED.annotations,
                resource_version = EXCLUDED.resource_version
            RETURNING tbl_{{ .Table }}.uid, tbl_{{ .Table }}.name
            INTO uid, name;
        ELSIF _op = 'del' THEN
            DELETE FROM {{ $.Schema }}.tbl_{{ .Table }}
            WHERE {{ $.Schema }}.tbl_{{ .Table }}.name = _row.name
              AND {{ $.Schema }}.tbl_{{ .Table }}.namespace = _row.namespace
            RETURNING tbl_{{ .Table }}.uid, tbl_{{ .Table }}.name
            INTO uid, name;
        END IF;
        IF uid IS NOT NULL THEN
            RETURN NEXT;
        END IF;
    END LOOP;
END;
$$;

{{ end }}
