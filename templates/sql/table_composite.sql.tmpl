{{ range .Res.Subtypes }}
-- Table: {{ $.Schema }}.tbl_{{ .Table }}
CREATE TABLE IF NOT EXISTS {{ $.Schema }}.tbl_{{ .Table }} (
    uid            uuid NOT NULL DEFAULT gen_random_uuid(),
    name           {{ $.Schema }}.rname NOT NULL,
    namespace      {{ $.Schema }}.rname NOT NULL,
    display_name   text NOT NULL DEFAULT '',
    description    text NOT NULL DEFAULT '',
    comment        text NOT NULL DEFAULT '',
    labels         hstore NOT NULL DEFAULT ''::hstore,
    annotations    hstore NOT NULL DEFAULT ''::hstore,
    resource_version  bigint NOT NULL DEFAULT 0,
    creation_timestamp timestamptz NOT NULL DEFAULT now(),

    CONSTRAINT pk_{{ .Table }} PRIMARY KEY (uid),
    CONSTRAINT uq_{{ .Table }}_name UNIQUE (namespace, name),
    CONSTRAINT fk_{{ .Table }}_namespace FOREIGN KEY (namespace)
        REFERENCES {{ $.Schema }}.{{ $.NamespaceTable }}(name)
        ON DELETE CASCADE
        DEFERRABLE INITIALLY DEFERRED
);

CREATE INDEX IF NOT EXISTS idx_{{ .Table }}_name
    ON {{ $.Schema }}.tbl_{{ .Table }} (name);
CREATE INDEX IF NOT EXISTS idx_{{ .Table }}_ns
    ON {{ $.Schema }}.tbl_{{ .Table }} (namespace);
CREATE INDEX IF NOT EXISTS idx_{{ .Table }}_rv
    ON {{ $.Schema }}.tbl_{{ .Table }} (resource_version);
{{ end }}
