-- DO NOT EDIT: generated by sgctl
-- Lister function: {{ .Schema }}.list_{{ .Res.Table }}s

CREATE OR REPLACE FUNCTION {{ .Schema }}.list_{{ .Res.Table }}s(
{{- if eq .Res.List.Selectors "res" }}
    _selectors {{ .Schema }}.res_selector[] DEFAULT NULL
{{- end }}
)
RETURNS SETOF {{ .Schema }}.vu_{{ .Res.Table }}
LANGUAGE sql STABLE
AS $$
    SELECT v.*
    FROM {{ .Schema }}.vu_{{ .Res.Table }} v
{{- if eq .Res.List.Selectors "res" }}
    WHERE (_selectors IS NULL OR {{ .Schema }}.match_res_selectors(
        v.name,
{{- if .Res.IsNamespaced }}
        v.namespace,
{{- else }}
        NULL::{{ .Schema }}.rname,
{{- end }}
        v.labels,
        _selectors
    ))
{{- end }}
    ORDER BY v.name;
$$;

