CREATE OR REPLACE VIEW {{ .Schema }}.vu_{{ .Res.Table }} AS
SELECT
    t.uid,
    t.name,
{{- if .Res.IsNamespaced }}
    t.namespace,
{{- end }}
{{- range .Res.Refs }}
    t.{{ .SQLColumn }},
{{- end }}
{{- range .Res.Spec.Fields }}
