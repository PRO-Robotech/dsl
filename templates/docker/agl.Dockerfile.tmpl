# ─── {{ .Project.Name }}-k8s-apiserver ──────────────────────────────────────
#
# Usage:  docker build -f build/docker/apiserver.Dockerfile -t {{ .Project.Name }}-k8s-apiserver .
#

FROM golang:1.22-alpine AS builder

RUN apk add --no-cache git ca-certificates protobuf protobuf-dev
RUN go install google.golang.org/protobuf/cmd/protoc-gen-go@v1.34.1 && \
    go install google.golang.org/grpc/cmd/protoc-gen-go-grpc@v1.3.0

RUN mkdir -p /proto-include/google/api && \
    wget -qO- https://github.com/googleapis/googleapis/archive/refs/heads/master.tar.gz | \
    tar xz --strip-components=1 -C /tmp googleapis-master && \
    cp /tmp/google/api/annotations.proto /tmp/google/api/http.proto /proto-include/google/api/ && \
    rm -rf /tmp/googleapis-master

WORKDIR /src
COPY go.mod go.su[m] ./
RUN go mod download 2>/dev/null || true
COPY . .

RUN protoc --go_out=. --go_opt=module={{ .Module }} \
           --go-grpc_out=. --go-grpc_opt=module={{ .Module }} \
           -I api/proto/ -I /proto-include \
           api/proto/{{ .Project.Name }}/v1/*.proto

RUN go mod tidy
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" \
    -o /bin/{{ .Project.Name }}-k8s-apiserver ./cmd/{{ .Project.Name }}-k8s-apiserver

FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /bin/{{ .Project.Name }}-k8s-apiserver /usr/local/bin/{{ .Project.Name }}-k8s-apiserver
EXPOSE 8443
ENTRYPOINT ["{{ .Project.Name }}-k8s-apiserver"]
