// NewPGRepository returns a Repository backed by PostgreSQL via pgxpool.
func NewPGRepository(pool *pgxpool.Pool, dsn string) Repository {
	return &pgRepo{pool: pool, dsn: dsn}
}

type pgRepo struct {
	pool *pgxpool.Pool
	dsn  string
}

func (r *pgRepo) Reader(ctx context.Context) Reader {
	return &pgReader{pool: r.pool, dsn: r.dsn}
}

func (r *pgRepo) Writer(ctx context.Context) (Writer, error) {
	tx, err := r.pool.Begin(ctx)
	if err != nil {
		return nil, fmt.Errorf("begin tx: %w", err)
	}
	return &pgWriter{tx: tx}, nil
}

