// ---------------------------------------------------------------------------
// Generic watch via LISTEN/NOTIFY + outbox
// ---------------------------------------------------------------------------

func watchResource[E any](
	ctx context.Context,
	pool *pgxpool.Pool,
	dsn string,
	channel string,
	convert func(op string, payload json.RawMessage) (E, error),
) (<-chan E, error) {
	conn, err := pgx.Connect(ctx, dsn)
	if err != nil {
		return nil, fmt.Errorf("connect for watch %s: %w", channel, err)
	}

	if _, err := conn.Exec(ctx, `LISTEN "`+channel+`"`); err != nil {
		conn.Close(ctx)
		return nil, fmt.Errorf("listen %s: %w", channel, err)
	}
	log.Printf("[watch] LISTEN %s established (dedicated conn)", channel)

	ch := make(chan E, 64)

	go func() {
		defer conn.Close(context.Background())
		defer close(ch)
		for {
			n, err := conn.WaitForNotification(ctx)
			if err != nil {
				if ctx.Err() != nil {
					return
				}
				log.Printf("[watch] %s: WaitForNotification error: %v", channel, err)
				return
			}
			log.Printf("[watch] %s: notification received payload=%s", channel, n.Payload)

			outboxID, err := strconv.ParseInt(n.Payload, 10, 64)
			if err != nil {
				log.Printf("[watch] %s: parse outbox id: %v", channel, err)
				continue
			}
			var op string
			var payload json.RawMessage
			err = pool.QueryRow(ctx,
				"SELECT operation::text, payload FROM {{ .DBSchema }}.tbl_outbox_resource_events WHERE id = $1",
				outboxID,
			).Scan(&op, &payload)
			if err != nil {
				log.Printf("[watch] %s: read outbox error: %v", channel, err)
				continue
			}
			ev, err := convert(op, payload)
			if err != nil {
				log.Printf("[watch] %s: convert error: %v", channel, err)
				continue
			}
			select {
			case ch <- ev:
			case <-ctx.Done():
				return
			}
		}
	}()
	return ch, nil
}

// ---------------------------------------------------------------------------
// syncResource helper
// ---------------------------------------------------------------------------

func syncResource[T any](ctx context.Context, tx pgx.Tx, sqlFunc string, op SyncOp, items []T, argsFunc func(T) []any, rowType string) error {
	if len(items) == 0 {
		return nil
	}
	opStr := "ups"
	if op == Delete {
		opStr = "del"
	}

	parts := strings.Split(sqlFunc, ".")
	schema := parts[0]
	funcName := parts[1]
	tableName := strings.TrimPrefix(funcName, "sync_")
	if strings.HasSuffix(tableName, "s") {
		tableName = tableName[:len(tableName)-1]
	}
	rowTypeName := fmt.Sprintf("%s.row_of__%s", schema, tableName)

	fieldTypes := parseRowType(rowType)

	var rowLiterals []string
	for _, item := range items {
		fields := argsFunc(item)
		parts := make([]string, len(fields))
		for i, f := range fields {
			parts[i] = sqlLiteral(f)
			if i < len(fieldTypes) {
				parts[i] += "::" + fieldTypes[i]
			}
		}
		rowLiterals = append(rowLiterals, fmt.Sprintf("ROW(%s)::%s", strings.Join(parts, ", "), rowTypeName))
	}

	query := fmt.Sprintf("SELECT * FROM %s('%s', ARRAY[%s]::%s[])", sqlFunc, opStr, strings.Join(rowLiterals, ", "), rowTypeName)

	_, err := tx.Exec(ctx, query, pgx.QueryExecModeSimpleProtocol)
	return err
}

func parseRowType(def string) []string {
	def = strings.TrimPrefix(def, "(")
	def = strings.TrimSuffix(def, ")")
	var types []string
	for _, part := range strings.Split(def, ",") {
		part = strings.TrimSpace(part)
		spaceIdx := strings.Index(part, " ")
		if spaceIdx >= 0 {
			types = append(types, strings.TrimSpace(part[spaceIdx+1:]))
		}
	}
	return types
}

func sqlLiteral(v any) string {
	if v == nil {
		return "NULL"
	}
	switch val := v.(type) {
	case string:
		return "'" + strings.ReplaceAll(val, "'", "''") + "'"
	case []byte:
		return "'" + strings.ReplaceAll(string(val), "'", "''") + "'"
	case bool:
		if val {
			return "true"
		}
		return "false"
	case int:
		return fmt.Sprintf("%d", val)
	case int64:
		return fmt.Sprintf("%d", val)
	case float64:
		return fmt.Sprintf("%v", val)
	default:
		s := fmt.Sprintf("%v", val)
		return "'" + strings.ReplaceAll(s, "'", "''") + "'"
	}
}

// ---------------------------------------------------------------------------
// hstore helpers
// ---------------------------------------------------------------------------

type pgHstore struct {
	m map[string]string
}

func (h *pgHstore) Scan(src any) error {
	h.m = make(map[string]string)
	if src == nil {
		return nil
	}
	switch v := src.(type) {
	case string:
		return h.parse(v)
	case []byte:
		return h.parse(string(v))
	default:
		return fmt.Errorf("pgHstore: unsupported type %T", src)
	}
}

func (h *pgHstore) parse(s string) error {
	s = strings.TrimSpace(s)
	if s == "" {
		return nil
	}
	for len(s) > 0 {
		s = strings.TrimLeft(s, " ,")
		if len(s) == 0 {
			break
		}
		key, rest := parseHstoreToken(s)
		rest = strings.TrimLeft(rest, " ")
		if !strings.HasPrefix(rest, "=>") {
			break
		}
		rest = rest[2:]
		rest = strings.TrimLeft(rest, " ")
		val, rest2 := parseHstoreToken(rest)
		h.m[key] = val
		s = rest2
	}
	return nil
}

func parseHstoreToken(s string) (string, string) {
	s = strings.TrimLeft(s, " ")
	if len(s) == 0 {
		return "", ""
	}
	if s[0] == '"' {
		end := 1
		for end < len(s) {
			if s[end] == '\\' {
				end += 2
				continue
			}
			if s[end] == '"' {
				token := strings.ReplaceAll(s[1:end], `\"`, `"`)
				token = strings.ReplaceAll(token, `\\`, `\`)
				return token, s[end+1:]
			}
			end++
		}
		return s[1:], ""
	}
	end := strings.IndexAny(s, " ,=>")
	if end < 0 {
		return s, ""
	}
	return s[:end], s[end:]
}

func parseHstoreString(s string) map[string]string {
	h := &pgHstore{}
	_ = h.parse(s)
	return h.m
}

func uuidOrNil(id uuid.UUID) any {
	if id == uuid.Nil {
		return nil
	}
	return id
}

func hstoreArg(m map[string]string) string {
	if len(m) == 0 {
		return ""
	}
	var parts []string
	for k, v := range m {
		ek := strings.ReplaceAll(strings.ReplaceAll(k, `\`, `\\`), `"`, `\"`)
		ev := strings.ReplaceAll(strings.ReplaceAll(v, `\`, `\\`), `"`, `\"`)
		parts = append(parts, fmt.Sprintf(`"%s"=>"%s"`, ek, ev))
	}
	return strings.Join(parts, ", ")
}

func parseRefs(data []byte) []{{ $.DomainPkg }}.ResourceRef {
	if len(data) == 0 {
		return nil
	}
	var refs []{{ $.DomainPkg }}.ResourceRef
	_ = json.Unmarshal(data, &refs)
	return refs
}
