{{ range $m := .Res.ExtraGRPCMethods }}
{{ if and $m.Scaffold $m.SyncerName }}
func (s *Service{{ $.Res.Name }}) {{ $m.Name }}(ctx context.Context, req *pb.{{ $.Res.Name }}Req_{{ $m.Name }}) (*pb.{{ $.Res.Name }}Resp_{{ $m.Name }}, error) {
	items := make([]{{ $.Project.Name }}.{{ $.Res.Name }}, 0, len(req.Get{{ resGoPlural $.Res.Name }}()))
	for _, pbItem := range req.Get{{ resGoPlural $.Res.Name }}() {
		d := dto.{{ $.Res.Name }}FromProto(pbItem)

		isZeroUID := d.Metadata.UID.String() == "" || d.Metadata.UID.String() == "00000000-0000-0000-0000-000000000000"
		if isZeroUID || d.Metadata.Name == "" || d.Metadata.Namespace == "" {
			return nil, status.Errorf(codes.InvalidArgument, "pass existing uid, name AND namespace; metadata.uid, metadata.name and metadata.namespace are all required for {{ $m.Name }}")
		}

		items = append(items, d)
	}

	writer, err := s.repo.Writer(ctx)
	if err != nil {
		return nil, err
	}
	defer func() { _ = writer.Abort(ctx) }()

	if err := writer.Sync{{ $m.SyncerName }}(ctx, sg.Upsert, items); err != nil {
		wrapped := sg.WrapPGError(err)
		st, ok := status.FromError(wrapped)
		if ok && st.Code() == codes.NotFound {
			return nil, status.Errorf(codes.NotFound, "pass existing name, namespace and uid; %s", st.Message())
		}
		return nil, wrapped
	}

	if err := writer.Commit(ctx); err != nil {
		return nil, sg.WrapPGError(err)
	}

	return &pb.{{ $.Res.Name }}Resp_{{ $m.Name }}{}, nil
}
