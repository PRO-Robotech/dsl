	{{ .Project.Name }} "{{ .Module }}/internal/shared/domains/{{ .Project.Name }}"
	sg "{{ .Module }}/internal/sg-server/repository"
	pb "{{ .Module }}/pkg/api/{{ .Project.Name }}/v1"
	"{{ .Module }}/internal/sg-server/transport/grpc/service/{{ lower .Res.Name }}/dto"
	"google.golang.org/grpc/codes"
