// UpdIPs updates the IP addresses of existing hosts.
// Requires uid + name + namespace to identify hosts.
func (s *Service{{ $.Res.Name }}) UpdIPs(ctx context.Context, req *pb.{{ $.Res.Name }}Req_UpdIPs) (*pb.{{ $.Res.Name }}Resp_UpdIPs, error) {
	items := make([]{{ $.Project.Name }}.{{ $.Res.Name }}, 0, len(req.Get{{ resGoPlural $.Res.Name }}()))
	for _, pbItem := range req.Get{{ resGoPlural $.Res.Name }}() {
		d := dto.{{ $.Res.Name }}FromProto(pbItem)

		if d.Metadata.UID.String() == "" || d.Metadata.UID.String() == "00000000-0000-0000-0000-000000000000" {
			return nil, status.Errorf(codes.InvalidArgument, "metadata.uid is required for UpdIPs")
		}
		if d.Metadata.Name == "" {
			return nil, status.Errorf(codes.InvalidArgument, "metadata.name is required for UpdIPs")
		}
		if d.Metadata.Namespace == "" {
			return nil, status.Errorf(codes.InvalidArgument, "metadata.namespace is required for UpdIPs")
		}

		items = append(items, d)
	}

	writer, err := s.repo.Writer(ctx)
	if err != nil {
		return nil, err
	}

	if err := writer.SyncHostIPs(ctx, sg.Upsert, items); err != nil {
		_ = writer.Abort(ctx)
		return nil, err
	}

	if err := writer.Commit(ctx); err != nil {
		return nil, err
	}

	return &pb.{{ $.Res.Name }}Resp_UpdIPs{}, nil
}
