package dto

import (
	{{ .Project.Name }} "{{ .Module }}/internal/shared/domains/{{ .Project.Name }}"
	pb "{{ .Module }}/pkg/api/{{ .Project.Name }}/v1"
)

// {{ .Res.Name }}SpecFromProto converts spec-specific fields from proto to domain.
// This file is generated once — customize spec field mapping here.
func {{ .Res.Name }}SpecFromProto(msg *pb.{{ .Res.Name }}, d *{{ .Project.Name }}.{{ .Res.Name }}) {
{{- range $field := .Res.Spec.Fields }}
{{- if eq $field.ConversionKind "passthrough" }}
	d.Spec.{{ goField $field.Name }} = msg.GetSpec().Get{{ goField $field.Name }}()
{{- else if eq $field.ConversionKind "string_cast" }}
	d.Spec.{{ goField $field.Name }} = {{ $.Project.Name }}.{{ $field.GoType }}(msg.GetSpec().Get{{ goField $field.Name }}())
{{- else if eq $field.ConversionKind "cidr" }}
	d.Spec.{{ goField $field.Name }} = {{ $.Project.Name }}.ParseIPNet(msg.GetSpec().Get{{ goField $field.Name }}())
{{- else if eq $field.ConversionKind "jsonb_struct" }}
{{- if $field.OutputOnly }}
{{- if and $field.ResolvedType (len $field.ResolvedType.GoFields) }}
	if src := msg.Get{{ goField $field.Name }}(); src != nil {
		d.{{ goField $field.Name }} = {{ $.Project.Name }}.{{ $field.GoType }}{
{{- range $field.ResolvedType.GoFields }}
			{{ .Name }}: src.Get{{ .ProtoName }}(),
{{- end }}
		}
	}
{{- else }}
	// TODO: map msg.Get{{ goField $field.Name }}() -> d.{{ goField $field.Name }}
{{- end }}
{{- else if $field.Repeated }}
	for _, item := range msg.GetSpec().Get{{ goField $field.Name }}() {
		d.Spec.{{ goField $field.Name }} = append(d.Spec.{{ goField $field.Name }}, convert{{ $field.ProtoType }}FromProto(item))
	}
{{- else }}
	// TODO: map msg field -> d.Spec.{{ goField $field.Name }}
{{- end }}
{{- else }}
	// TODO: map msg field -> d.Spec.{{ goField $field.Name }}
{{- end }}
{{- end }}
{{- if not (len .Res.Spec.Fields) }}
	// No spec fields to map.
{{- end }}
}
{{ range $field := .Res.Spec.Fields }}
{{- if and (eq $field.ConversionKind "jsonb_struct") $field.Repeated (not $field.OutputOnly) $field.ResolvedType }}

func convert{{ $field.ProtoType }}FromProto(item *pb.{{ $field.ProtoType }}) {{ $.Project.Name }}.{{ $field.GoType }} {
	out := {{ $.Project.Name }}.{{ $field.GoType }}{}
{{- range $gf := $field.ResolvedType.GoFields }}
{{- if hasPrefix $gf.Type "[]" }}
{{- $innerGoType := trimPrefix $gf.Type "[]" }}
{{- range $ct := $.Types }}
{{- if eq $ct.Mapping.Go $innerGoType }}
	for _, sub := range item.Get{{ $gf.ProtoName }}() {
		domSub := {{ $.Project.Name }}.{{ $ct.Mapping.Go }}{
{{- range $cf := $ct.GoFields }}
{{- if hasPrefix $cf.Type "[]" }}
			{{ $cf.Name }}: sub.Get{{ $cf.ProtoName }}(),
{{- else }}
			{{ $cf.Name }}: {{ $.Project.Name }}.{{ $cf.Type }}(sub.Get{{ $cf.ProtoName }}()),
{{- end }}
{{- end }}
		}
		out.{{ $gf.Name }} = append(out.{{ $gf.Name }}, domSub)
	}
{{- end }}
{{- end }}
{{- else }}
	out.{{ $gf.Name }} = {{ $.Project.Name }}.{{ $gf.Type }}(item.Get{{ $gf.ProtoName }}())
{{- end }}
{{- end }}
	return out
}
{{- end }}
{{- end }}
