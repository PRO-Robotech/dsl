package dto

import (
	{{ .Project.Name }} "{{ .Module }}/internal/shared/domains/{{ .Project.Name }}"
	pb "{{ .Module }}/pkg/api/{{ .Project.Name }}/v1"
)

// {{ .Res.Name }}SpecToProto converts spec-specific fields from domain to proto.
// This file is generated once — customize spec field mapping here.
func {{ .Res.Name }}SpecToProto(d {{ .Project.Name }}.{{ .Res.Name }}, msg *pb.{{ .Res.Name }}) {
{{- range $field := .Res.Spec.Fields }}
{{- if eq $field.ConversionKind "passthrough" }}
	msg.Spec.{{ goField $field.Name }} = d.Spec.{{ goField $field.Name }}
{{- else if eq $field.ConversionKind "string_cast" }}
	msg.Spec.{{ goField $field.Name }} = string(d.Spec.{{ goField $field.Name }})
{{- else if eq $field.ConversionKind "cidr" }}
	msg.Spec.{{ goField $field.Name }} = d.Spec.{{ goField $field.Name }}.String()
{{- else if eq $field.ConversionKind "jsonb_struct" }}
{{- if $field.OutputOnly }}
{{- if and $field.ResolvedType (len $field.ResolvedType.GoFields) }}
	msg.{{ goField $field.Name }} = &pb.{{ $field.ProtoType }}{
{{- range $field.ResolvedType.GoFields }}
		{{ .ProtoName }}: d.{{ goField $field.Name }}.{{ .Name }},
{{- end }}
	}
{{- else }}
	// TODO: map d.{{ goField $field.Name }} -> msg.{{ goField $field.Name }}
{{- end }}
{{- else if $field.Repeated }}
	for _, item := range d.Spec.{{ goField $field.Name }} {
		msg.Spec.{{ goField $field.Name }} = append(msg.Spec.{{ goField $field.Name }}, convert{{ $field.ProtoType }}ToProto(item))
	}
{{- else }}
	// TODO: map d.Spec.{{ goField $field.Name }} -> msg.Spec.{{ goField $field.Name }}
{{- end }}
{{- else }}
	// TODO: map d.Spec.{{ goField $field.Name }} -> msg.Spec.{{ goField $field.Name }}
{{- end }}
{{- end }}
{{- if not (len .Res.Spec.Fields) }}
	// No spec fields to map.
{{- end }}
}
{{ range $field := .Res.Spec.Fields }}
{{- if and (eq $field.ConversionKind "jsonb_struct") $field.Repeated (not $field.OutputOnly) $field.ResolvedType }}

func convert{{ $field.ProtoType }}ToProto(item {{ $.Project.Name }}.{{ $field.GoType }}) *pb.{{ $field.ProtoType }} {
	out := &pb.{{ $field.ProtoType }}{}
{{- range $gf := $field.ResolvedType.GoFields }}
{{- if hasPrefix $gf.Type "[]" }}
{{- $innerGoType := trimPrefix $gf.Type "[]" }}
{{- range $ct := $.Types }}
{{- if eq $ct.Mapping.Go $innerGoType }}
	for _, sub := range item.{{ $gf.Name }} {
		pbSub := &pb.{{ $ct.ProtoName }}{}
{{- range $cf := $ct.GoFields }}
{{- if hasPrefix $cf.Type "[]" }}
		pbSub.{{ $cf.ProtoName }} = sub.{{ $cf.Name }}
{{- else }}
		pbSub.{{ $cf.ProtoName }} = string(sub.{{ $cf.Name }})
{{- end }}
{{- end }}
		out.{{ $gf.ProtoName }} = append(out.{{ $gf.ProtoName }}, pbSub)
	}
{{- end }}
{{- end }}
{{- else }}
	out.{{ $gf.ProtoName }} = string(item.{{ $gf.Name }})
{{- end }}
{{- end }}
	return out
}
{{- end }}
{{- end }}
